[
  {
    "comment": "Block third-party requests to common ad / analytics / social trackers.",
    "trigger": {
      "url-filter": ".*",
      "load-type": ["third-party"],
      "if-domain": [
        "*doubleclick.net",
        "*google-analytics.com",
        "*googletagmanager.com",
        "*googletagservices.com",
        "*adservice.google.com",
        "*adsense.google.com",
        "*facebook.net",
        "*fbcdn.net",
        "*amazon-adsystem.com",
        "*criteo.com",
        "*criteo.net",
        "*scorecardresearch.com",
        "*quantserve.com",
        "*adnxs.com",
        "*taboola.com",
        "*outbrain.com",
        "*mixpanel.com",
        "*segment.io",
        "*hotjar.com",
        "*clarity.ms",
        "*yandex.ru"
      ]
    },
    "action": { "type": "block" }
  },
  {
    "comment": "Block third-party tracking pixels / beacons.",
    "trigger": {
      "url-filter": ".*",
      "resource-type": ["image", "raw"],
      "load-type": ["third-party"]
    },
    "action": { "type": "block" }
  },
  {
    "comment": "Ignore Set-Cookie on third-party responses to reduce cross-site tracking.",
    "trigger": {
      "url-filter": ".*",
      "load-type": ["third-party"]
    },
    "action": { "type": "block-cookies" }
  }
]
